--Rimozione del num di citazioni
CREATE OR REPLACE FUNCTION dec_n_citazioni()
    RETURNS TRIGGER
    LANGUAGE plpgsql AS $$
    DECLARE
        n integer;
    BEGIN
        SELECT NumeroCitazioni INTO n
        FROM PUBBLICAZIONI
        WHERE Codice = OLD.PubblicazioneCitata;

        IF NOT FOUND THEN
            RETURN NULL;
        ELSE
            UPDATE PUBBLICAZIONI
            SET NumeroCitazioni = n-1
            WHERE Codice = OLD.PubblicazioneCitata;
        END IF;
        RETURN OLD;
    END;
$$;

--Update citazioni, controlla che non si citi da sola e gestisce il campo derivato
--HA SENSO???
CREATE or REPLACE FUNCTION updt_citazioni()
	RETURNS trigger LANGUAGE plpgsql AS $$
	BEGIN
		RAISE EXCEPTION 'Una citazione non può essere aggiornata si consiglia di aggiungerne una nuova ed eliminare la vecchia';
	END;
$$;

CREATE or REPLACE TRIGGER trg_ins_CIT
BEFORE INSERT ON CITAZIONI
FOR EACH ROW EXECUTE FUNCTION inc_n_citazioni();

CREATE or REPLACE TRIGGER trg_dec_CIT
BEFORE DELETE ON CITAZIONI
FOR EACH ROW EXECUTE FUNCTION dec_n_citazioni();

CREATE or REPLACE TRIGGER trg_upd_CIT
BEFORE UPDATE ON CITAZIONI
FOR EACH ROW EXECUTE FUNCTION updt_citazioni();
