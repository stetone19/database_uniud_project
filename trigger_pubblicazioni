--1)modifica num di citazioni
--Aggiunta del num di citazioni
--PRIMA O DOPO L'INSERIMENTO???
CREATE OR REPLACE FUNCTION inc_n_citazioni()
    RETURNS TRIGGER LANGUAGE plpgsql AS $$
    DECLARE
        n integer;
        Anno_citante integer;
        Anno_citata integer;
    BEGIN
        SELECT Anno INTO Anno_citante
        FROM PUBBLICAZIONI
        WHERE Codice = NEW.PubblicazioneCitante;

        SELECT Anno, NumeroCitazioni INTO Anno_citata, n
        FROM PUBBLICAZIONI
        WHERE Codice = NEW.PubblicazioneCitata;

        IF NEW.PubblicazioneCitante = NEW.PubblicazioneCitata THEN
            RAISE EXCEPTION 'Una pubblicazione non si può citare da sola';
        END IF;
        IF Anno_citante < Anno_citata THEN
            RAISE EXCEPTION 'Una pubblicazione può citare solo pubblicazioni contemporanee o più vecchie';
        ELSE
            IF n = 0 THEN
                UPDATE PUBBLICAZIONI
                SET NumeroCitazioni = 1
                WHERE Codice = NEW.PubblicazioneCitata;
            ELSE
                UPDATE PUBBLICAZIONI
                SET NumeroCitazioni = n+1
                WHERE Codice = NEW.PubblicazioneCitata;
            END IF;
            RETURN NEW;
        END IF;
    END;
$$;
